# Python bytecode and test/tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Python environments and packaging output
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Local updater/runtime state. Project lockfiles belong outside these folders.
.tdimagefx/
.imagefx/
cache/
downloads/
staging/
quarantine/

# Local Embody/Envoy QA project and generated assistant configuration
integrations/embody/local/

# Credentials and local secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*credentials*.json
*secrets*.json

# TouchDesigner numbered saves, crash recovery, and temporary files
*.[0-9].toe
*.[0-9][0-9].toe
*.[0-9][0-9][0-9].toe
*.toe.autosave
*.toe.tmp
*.tox.tmp

# Logs and profiling captures
*.log
*.trace
*.prof

# Editors and operating systems
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# Embody / Envoy (auto-managed)
Backup/
logs/
CrashAutoSave*
.mcp.json
.embody/*
!.embody/project.json
.claude/settings.local.json
.claude/projects/
