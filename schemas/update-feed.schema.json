{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "update-feed.schema.json",
  "title": "TD ImageFX Update Feed",
  "description": "Remote catalog of available package releases and downloadable artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "feed_id",
    "generated_at",
    "channel",
    "packages"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "feed_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "maxLength": 180
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "channel": {
      "$ref": "#/$defs/channel"
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/package_releases"
      }
    },
    "signature": {
      "anyOf": [
        {
          "$ref": "#/$defs/signature"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "package_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "maxLength": 180
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "channel": {
      "enum": [
        "stable",
        "beta",
        "experimental"
      ]
    },
    "kind": {
      "enum": [
        "effect",
        "shader",
        "plugin",
        "technique",
        "adapter",
        "preset",
        "modulator",
        "example",
        "core"
      ]
    },
    "build": {
      "anyOf": [
        {
          "type": "number",
          "exclusiveMinimum": 0
        },
        {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+)+$"
        }
      ]
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "touchdesigner_min_build",
        "touchdesigner_max_build",
        "os",
        "architectures"
      ],
      "properties": {
        "touchdesigner_min_build": {
          "$ref": "#/$defs/build"
        },
        "touchdesigner_max_build": {
          "anyOf": [
            {
              "$ref": "#/$defs/build"
            },
            {
              "type": "null"
            }
          ]
        },
        "os": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "windows",
              "macos"
            ]
          }
        },
        "architectures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "x86_64",
              "arm64"
            ]
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "ed25519",
            "rsa_pss_sha256",
            "ecdsa_p384_sha384"
          ]
        },
        "key_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16384
        }
      }
    },
    "package_releases": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "releases"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/package_id"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "kind": {
          "$ref": "#/$defs/kind"
        },
        "releases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/release"
          }
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "channel",
        "published_at",
        "manifest_url",
        "manifest_sha256",
        "artifacts",
        "compatibility",
        "requires_restart",
        "yanked",
        "changelog"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/semver"
        },
        "channel": {
          "$ref": "#/$defs/channel"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "manifest_url": {
          "type": "string",
          "format": "uri"
        },
        "manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "compatibility": {
          "$ref": "#/$defs/compatibility"
        },
        "requires_restart": {
          "type": "boolean"
        },
        "yanked": {
          "type": "boolean"
        },
        "changelog": {
          "type": "string",
          "maxLength": 20000
        },
        "security_advisory": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 10000
        },
        "permissions_changed": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "sha256",
        "size_bytes",
        "os",
        "architectures"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "os": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "windows",
              "macos"
            ]
          }
        },
        "architectures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "x86_64",
              "arm64"
            ]
          }
        },
        "signature": {
          "anyOf": [
            {
              "$ref": "#/$defs/signature"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
