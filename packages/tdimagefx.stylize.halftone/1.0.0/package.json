{
  "schema_version": 1,
  "id": "tdimagefx.stylize.halftone",
  "name": "Halftone",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "stylize",
  "channel": "stable",
  "description": "Renders luminance as an angle-adjustable field of print-style halftone dots.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/halftone.frag", "touchdesigner_component": "tox/tdimagefx_stylize_halftone.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "cell_size", "name": "Cellsize", "label": "Cell Size", "type": "float", "default": 10.0, "min": 2.0, "max": 64.0, "uniform": "uCellSize", "unit": "pixels"},
    {"id": "angle", "name": "Angle", "type": "float", "default": 0.35, "min": -3.14159, "max": 3.14159, "uniform": "uAngle", "unit": "radians"},
    {"id": "dot_size", "name": "Dotsize", "label": "Dot Size", "type": "float", "default": 1.0, "min": 0.1, "max": 1.5, "uniform": "uDotSize"},
    {"id": "softness", "name": "Softness", "type": "float", "default": 0.06, "min": 0.001, "max": 0.3, "uniform": "uSoftness"},
    {"id": "monochrome", "name": "Monochrome", "type": "toggle", "default": true, "uniform": "uMonochrome"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["print", "dots", "comic", "screening"]
}
