{
  "schema_version": 1,
  "id": "tdimagefx.temporal.temporal-glitch",
  "name": "Temporal Glitch",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "temporal",
  "channel": "stable",
  "description": "Replaces randomized image blocks with offset history for controllable digital dropouts.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/temporal_glitch.frag",
    "touchdesigner_component": "tox/tdimagefx_temporal_temporal_glitch.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "amount",
      "name": "Amount",
      "type": "float",
      "default": 0.35,
      "min": 0,
      "max": 1,
      "uniform": "uAmount"
    },
    {
      "id": "block_size",
      "name": "Blocksize",
      "type": "float",
      "default": 24,
      "min": 2,
      "max": 128,
      "uniform": "uBlockSize"
    },
    {
      "id": "phase",
      "name": "Phase",
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 1000,
      "uniform": "uPhase"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "glitch",
    "blocks",
    "dropout",
    "history"
  ],
  "processing": {
    "model": "temporal",
    "gpu_cost": "medium",
    "capabilities": [
      "history"
    ],
    "passes": [
      "shaders/temporal_glitch.frag"
    ],
    "history_frames": 1
  }
}
