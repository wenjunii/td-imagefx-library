{
  "schema_version": 1,
  "id": "tdimagefx.blur.depth-aware-blur",
  "name": "Depth Aware Blur",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "blur",
  "channel": "experimental",
  "description": "Applies depth-of-field blur using a depth-map focus plane and edge-aware sample rejection.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/depth_aware_blur.frag", "touchdesigner_component": "tox/tdimagefx_blur_depth_aware_blur.tox"},
  "inputs": [
    {"id": "image", "family": "TOP", "required": true, "semantic": "source", "role": "source_image", "description": "Color image to blur."},
    {"id": "depth", "family": "TOP", "required": true, "semantic": "depth", "role": "depth", "description": "Normalized depth map aligned with the color image."}
  ],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass depth blur when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and depth-blurred output."},
    {"id": "focus", "name": "Focus", "label": "Focus Depth", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uFocus", "description": "Depth value kept in focus."},
    {"id": "aperture", "name": "Aperture", "label": "Aperture", "type": "float", "default": 2.0, "min": 0.0, "max": 10.0, "uniform": "uAperture", "description": "Scales blur according to distance from the focus plane."},
    {"id": "max_radius", "name": "Maxradius", "label": "Maximum Radius", "type": "float", "default": 16.0, "min": 0.0, "max": 64.0, "unit": "pixels", "uniform": "uMaxRadius", "description": "Maximum circle-of-confusion radius."},
    {"id": "edge_tolerance", "name": "Edgetolerance", "label": "Depth Edge Tolerance", "type": "float", "default": 0.08, "min": 0.001, "max": 1.0, "uniform": "uEdgeTolerance", "description": "Rejects samples crossing larger depth discontinuities."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "first_input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["blur", "depth", "depth-of-field", "focus", "two-input"],
  "processing": {"model": "single_pass", "gpu_cost": "high", "capabilities": ["second_input", "depth"], "passes": ["shaders/depth_aware_blur.frag"], "history_frames": 0}
}
