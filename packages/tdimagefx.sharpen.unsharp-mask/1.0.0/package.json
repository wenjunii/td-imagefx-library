{
  "schema_version": 1,
  "id": "tdimagefx.sharpen.unsharp-mask",
  "name": "Unsharp Mask",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "sharpen",
  "channel": "stable",
  "description": "Builds a separable Gaussian reference and adds thresholded high-frequency detail back to the source.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/pass1.frag",
    "touchdesigner_component": "tox/tdimagefx_sharpen_unsharp_mask.tox"
  },
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "radius", "name": "Radius", "type": "float", "default": 2.0, "min": 0.25, "max": 16.0, "unit": "pixels", "uniform": "uRadius"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 1.0, "min": 0.0, "max": 4.0, "uniform": "uAmount"},
    {"id": "threshold", "name": "Threshold", "type": "float", "default": 0.02, "min": 0.0, "max": 0.25, "uniform": "uThreshold"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["sharpen", "unsharp-mask", "detail", "multi-pass"],
  "processing": {
    "model": "multi_pass",
    "gpu_cost": "high",
    "capabilities": ["multi_pass"],
    "passes": ["shaders/pass1.frag", "shaders/pass2.frag", "shaders/pass3.frag"]
  }
}
