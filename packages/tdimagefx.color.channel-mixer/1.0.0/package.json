{
  "schema_version": 1,
  "id": "tdimagefx.color.channel-mixer",
  "name": "Channel Mixer",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Recombines RGB input channels through a configurable three-by-three color matrix.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/channel_mixer.frag", "touchdesigner_component": "tox/tdimagefx_color_channel_mixer.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "red_from_red", "name": "Redfromred", "label": "Red from Red", "type": "float", "default": 1.0, "min": -2.0, "max": 2.0, "uniform": "uRedFromRed"},
    {"id": "red_from_green", "name": "Redfromgreen", "label": "Red from Green", "type": "float", "default": 0.0, "min": -2.0, "max": 2.0, "uniform": "uRedFromGreen"},
    {"id": "red_from_blue", "name": "Redfromblue", "label": "Red from Blue", "type": "float", "default": 0.0, "min": -2.0, "max": 2.0, "uniform": "uRedFromBlue"},
    {"id": "green_from_red", "name": "Greenfromred", "label": "Green from Red", "type": "float", "default": 0.0, "min": -2.0, "max": 2.0, "uniform": "uGreenFromRed"},
    {"id": "green_from_green", "name": "Greenfromgreen", "label": "Green from Green", "type": "float", "default": 1.0, "min": -2.0, "max": 2.0, "uniform": "uGreenFromGreen"},
    {"id": "green_from_blue", "name": "Greenfromblue", "label": "Green from Blue", "type": "float", "default": 0.0, "min": -2.0, "max": 2.0, "uniform": "uGreenFromBlue"},
    {"id": "blue_from_red", "name": "Bluefromred", "label": "Blue from Red", "type": "float", "default": 0.0, "min": -2.0, "max": 2.0, "uniform": "uBlueFromRed"},
    {"id": "blue_from_green", "name": "Bluefromgreen", "label": "Blue from Green", "type": "float", "default": 0.0, "min": -2.0, "max": 2.0, "uniform": "uBlueFromGreen"},
    {"id": "blue_from_blue", "name": "Bluefromblue", "label": "Blue from Blue", "type": "float", "default": 1.0, "min": -2.0, "max": 2.0, "uniform": "uBlueFromBlue"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["channels", "matrix", "color-transform", "rgb"]
}
