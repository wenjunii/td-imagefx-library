{
  "schema_version": 1,
  "id": "tdimagefx.temporal.echo",
  "name": "Echo",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "temporal",
  "channel": "stable",
  "description": "Layers a displaced, color-tinted echo from the previous frame behind the source.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/echo.frag",
    "touchdesigner_component": "tox/tdimagefx_temporal_echo.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source",
      "role": "source_image",
      "description": "Current source image. Its alpha is preserved by the display pass."
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP",
      "role": "image",
      "description": "Rendered effect image; private temporal state is never exposed here."
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "reset",
      "name": "Reset",
      "label": "Reset State",
      "type": "pulse",
      "default": false,
      "description": "Clears private state and reseeds it from the current source image.",
      "animatable": false
    },
    {
      "id": "feedback",
      "name": "Feedback",
      "type": "float",
      "default": 0.7,
      "min": 0,
      "max": 0.98,
      "uniform": "uFeedback"
    },
    {
      "id": "offset_x",
      "name": "Offsetx",
      "type": "float",
      "default": 0.012,
      "min": -0.2,
      "max": 0.2,
      "uniform": "uOffsetX"
    },
    {
      "id": "offset_y",
      "name": "Offsety",
      "type": "float",
      "default": 0.008,
      "min": -0.2,
      "max": 0.2,
      "uniform": "uOffsetY"
    },
    {
      "id": "tint",
      "name": "Tint",
      "type": "rgba",
      "default": [
        0.9,
        0.75,
        1,
        1
      ],
      "uniform": "uTint"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "echo",
    "delay",
    "color",
    "history"
  ],
  "processing": {
    "model": "temporal",
    "gpu_cost": "medium",
    "capabilities": [
      "history"
    ],
    "passes": [
      "shaders/echo.frag",
      "shaders/render.frag"
    ],
    "history_frames": 1,
    "state_pass": "shaders/echo.frag",
    "render_pass": "shaders/render.frag"
  },
  "image_contract": {
    "color": {
      "input_space": "project",
      "working_space": "project",
      "output_space": "project",
      "reference": "scene_referred"
    },
    "alpha": {
      "input": "any",
      "working": "any",
      "output": "any"
    },
    "pixel_format": {
      "policy": "inherit"
    },
    "sampling": {
      "filter": "linear",
      "edge": "clamp",
      "mipmaps": false
    }
  },
  "determinism": {
    "mode": "deterministic",
    "fixed_timestep": 1.0
  },
  "temporal": {
    "reset": {
      "strategy": "pulse_parameter",
      "parameter": "reset",
      "clears": "history",
      "on_resolution_change": true,
      "on_input_change": false
    },
    "warmup_frames": 1
  },
  "provenance": {
    "origin": "original",
    "source": {
      "type": "original",
      "author": "TD ImageFX Library",
      "license": "MIT"
    },
    "known_limitations": [
      "State advances once per TouchDesigner cook and therefore depends on the upstream frame sequence."
    ]
  }
}
