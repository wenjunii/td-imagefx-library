{
  "schema_version": 1,
  "id": "tdimagefx.stylize.sepia",
  "name": "Sepia",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "stylize",
  "channel": "stable",
  "description": "Builds a controllable warm sepia palette from luminance and retained source chroma.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/sepia.frag", "touchdesigner_component": "tox/tdimagefx_stylize_sepia.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "warmth", "name": "Warmth", "type": "float", "default": 1.0, "min": 0.0, "max": 2.0, "uniform": "uWarmth"},
    {"id": "fade", "name": "Fade", "type": "float", "default": 0.85, "min": 0.0, "max": 1.0, "uniform": "uFade"},
    {"id": "contrast", "name": "Contrast", "type": "float", "default": 1.05, "min": 0.0, "max": 3.0, "uniform": "uContrast"},
    {"id": "paper", "name": "Paper", "type": "float", "default": 0.04, "min": 0.0, "max": 0.4, "uniform": "uPaper"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["vintage", "warm", "monochrome", "photographic"]
}
