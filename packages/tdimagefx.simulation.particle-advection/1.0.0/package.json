{
  "schema_version": 1,
  "id": "tdimagefx.simulation.particle-advection",
  "name": "Particle Advection",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "simulation",
  "channel": "experimental",
  "description": "Advects bright source particles through a procedural vector field with persistent trails.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/particle_advection.frag",
    "touchdesigner_component": "tox/tdimagefx_simulation_particle_advection.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "speed",
      "name": "Speed",
      "type": "float",
      "default": 0.008,
      "min": 0,
      "max": 0.1,
      "uniform": "uSpeed"
    },
    {
      "id": "decay",
      "name": "Decay",
      "type": "float",
      "default": 0.97,
      "min": 0,
      "max": 1,
      "uniform": "uDecay"
    },
    {
      "id": "threshold",
      "name": "Threshold",
      "type": "float",
      "default": 0.65,
      "min": 0,
      "max": 1,
      "uniform": "uThreshold"
    },
    {
      "id": "phase",
      "name": "Phase",
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 1000,
      "uniform": "uPhase"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "particle",
    "advection",
    "flow",
    "simulation"
  ],
  "processing": {
    "model": "simulation",
    "gpu_cost": "high",
    "capabilities": [
      "history",
      "simulation"
    ],
    "passes": [
      "shaders/particle_advection.frag"
    ],
    "history_frames": 1
  }
}
