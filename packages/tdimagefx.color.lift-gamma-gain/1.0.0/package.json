{
  "schema_version": 1,
  "id": "tdimagefx.color.lift-gamma-gain",
  "name": "Lift Gamma Gain",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Provides independent RGB lift, gamma, and gain controls for primary color correction.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/lift_gamma_gain.frag", "touchdesigner_component": "tox/tdimagefx_color_lift_gamma_gain.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "lift_r", "name": "Liftr", "label": "Lift R", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uLiftR"},
    {"id": "lift_g", "name": "Liftg", "label": "Lift G", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uLiftG"},
    {"id": "lift_b", "name": "Liftb", "label": "Lift B", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uLiftB"},
    {"id": "gamma_r", "name": "Gammar", "label": "Gamma R", "type": "float", "default": 1.0, "min": 0.1, "max": 4.0, "uniform": "uGammaR"},
    {"id": "gamma_g", "name": "Gammag", "label": "Gamma G", "type": "float", "default": 1.0, "min": 0.1, "max": 4.0, "uniform": "uGammaG"},
    {"id": "gamma_b", "name": "Gammab", "label": "Gamma B", "type": "float", "default": 1.0, "min": 0.1, "max": 4.0, "uniform": "uGammaB"},
    {"id": "gain_r", "name": "Gainr", "label": "Gain R", "type": "float", "default": 1.0, "min": 0.0, "max": 4.0, "uniform": "uGainR"},
    {"id": "gain_g", "name": "Gaing", "label": "Gain G", "type": "float", "default": 1.0, "min": 0.0, "max": 4.0, "uniform": "uGainG"},
    {"id": "gain_b", "name": "Gainb", "label": "Gain B", "type": "float", "default": 1.0, "min": 0.0, "max": 4.0, "uniform": "uGainB"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["lift", "gamma", "gain", "primary-correction"]
}
