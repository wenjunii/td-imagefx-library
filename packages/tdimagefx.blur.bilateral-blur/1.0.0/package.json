{
  "schema_version": 1,
  "id": "tdimagefx.blur.bilateral-blur",
  "name": "Bilateral Blur",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "blur",
  "channel": "experimental",
  "description": "Applies a separable edge-aware bilateral blur using spatial and color-distance weights.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/pass1.frag", "touchdesigner_component": "tox/tdimagefx_blur_bilateral_blur.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "role": "source_image", "description": "Image to smooth while retaining major edges."}],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the blur when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and blurred output."},
    {"id": "radius", "name": "Radius", "label": "Radius", "type": "float", "default": 5.0, "min": 1.0, "max": 12.0, "unit": "pixels", "uniform": "uRadius", "description": "Maximum sample distance on each axis."},
    {"id": "spatial_sigma", "name": "Spatialsigma", "label": "Spatial Sigma", "type": "float", "default": 4.0, "min": 0.1, "max": 24.0, "unit": "pixels", "uniform": "uSpatialSigma", "description": "Controls distance-based sample falloff."},
    {"id": "range_sigma", "name": "Rangesigma", "label": "Range Sigma", "type": "float", "default": 0.15, "min": 0.001, "max": 2.0, "uniform": "uRangeSigma", "description": "Controls rejection of samples with different color."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["blur", "bilateral", "edge-aware", "denoise", "multi-pass"],
  "processing": {"model": "multi_pass", "gpu_cost": "high", "capabilities": ["multi_pass"], "passes": ["shaders/pass1.frag", "shaders/pass2.frag"], "history_frames": 0}
}
