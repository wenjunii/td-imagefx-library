{
  "schema_version": 1,
  "id": "tdimagefx.distort.flow-field-warp",
  "name": "Flow Field Warp",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "distortion",
  "channel": "stable",
  "description": "Warps the source with an external RG vector field; it does not compute the field.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/flow_field_warp.frag",
    "touchdesigner_component": "tox/tdimagefx_distort_flow_field_warp.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    },
    {
      "id": "flow",
      "family": "TOP",
      "required": true,
      "semantic": "flow"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "amount",
      "name": "Amount",
      "type": "float",
      "default": 0.05,
      "min": -0.5,
      "max": 0.5,
      "uniform": "uAmount"
    },
    {
      "id": "bias_x",
      "name": "Biasx",
      "type": "float",
      "default": 0,
      "min": -1,
      "max": 1,
      "uniform": "uBiasX"
    },
    {
      "id": "bias_y",
      "name": "Biasy",
      "type": "float",
      "default": 0,
      "min": -1,
      "max": 1,
      "uniform": "uBiasY"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": [
    "flow",
    "vector-field",
    "warp",
    "displacement"
  ],
  "processing": {
    "model": "single_pass",
    "gpu_cost": "medium",
    "capabilities": [
      "second_input",
      "flow",
      "displacement"
    ],
    "passes": [
      "shaders/flow_field_warp.frag"
    ],
    "history_frames": 0
  }
}
