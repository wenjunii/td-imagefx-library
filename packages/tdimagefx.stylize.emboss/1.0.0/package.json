{
  "schema_version": 1,
  "id": "tdimagefx.stylize.emboss",
  "name": "Emboss",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "stylize",
  "channel": "stable",
  "description": "Creates directional raised and recessed relief from opposing image samples.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/emboss.frag", "touchdesigner_component": "tox/tdimagefx_stylize_emboss.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "angle", "name": "Angle", "type": "float", "default": 0.785398, "min": -3.14159, "max": 3.14159, "uniform": "uAngle", "unit": "radians"},
    {"id": "distance", "name": "Distance", "type": "float", "default": 2.0, "min": 0.5, "max": 20.0, "uniform": "uDistance", "unit": "pixels"},
    {"id": "strength", "name": "Strength", "type": "float", "default": 1.5, "min": 0.0, "max": 5.0, "uniform": "uStrength"},
    {"id": "bias", "name": "Bias", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uBias"},
    {"id": "color_amount", "name": "Coloramount", "label": "Color Amount", "type": "float", "default": 0.0, "min": 0.0, "max": 1.0, "uniform": "uColorAmount"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["relief", "directional", "carve", "texture"]
}
