{
  "schema_version": 1,
  "id": "tdimagefx.temporal.feedback-trails",
  "name": "Feedback Trails",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "temporal",
  "channel": "stable",
  "description": "Accumulates luminous trails from prior frames with controllable drift and decay.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/feedback_trails.frag",
    "touchdesigner_component": "tox/tdimagefx_temporal_feedback_trails.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "feedback",
      "name": "Feedback",
      "type": "float",
      "default": 0.88,
      "min": 0,
      "max": 0.995,
      "uniform": "uFeedback"
    },
    {
      "id": "decay",
      "name": "Decay",
      "type": "float",
      "default": 0.97,
      "min": 0,
      "max": 1,
      "uniform": "uDecay"
    },
    {
      "id": "offset_x",
      "name": "Offsetx",
      "type": "float",
      "default": 0.002,
      "min": -0.05,
      "max": 0.05,
      "uniform": "uOffsetX"
    },
    {
      "id": "offset_y",
      "name": "Offsety",
      "type": "float",
      "default": 0.002,
      "min": -0.05,
      "max": 0.05,
      "uniform": "uOffsetY"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "feedback",
    "trails",
    "echo",
    "history"
  ],
  "processing": {
    "model": "temporal",
    "gpu_cost": "medium",
    "capabilities": [
      "history"
    ],
    "passes": [
      "shaders/feedback_trails.frag"
    ],
    "history_frames": 1
  }
}
