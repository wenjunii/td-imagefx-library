{
  "schema_version": 1,
  "id": "tdimagefx.glitch.digital-noise",
  "name": "Digital Noise",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "glitch",
  "channel": "stable",
  "description": "Adds seeded, frame-stepped monochrome or RGB digital noise at adjustable pixel sizes.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/digital_noise.frag", "touchdesigner_component": "tox/tdimagefx_glitch_digital_noise.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "time", "name": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "uniform": "uTime"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.18, "min": 0.0, "max": 1.0, "uniform": "uAmount"},
    {"id": "pixel_size", "name": "Pixelsize", "label": "Pixel Size", "type": "float", "default": 2.0, "min": 1.0, "max": 64.0, "uniform": "uPixelSize"},
    {"id": "rate", "name": "Rate", "type": "float", "default": 24.0, "min": 0.0, "max": 120.0, "uniform": "uRate"},
    {"id": "monochrome", "name": "Monochrome", "type": "toggle", "default": false, "uniform": "uMonochrome"},
    {"id": "seed", "name": "Seed", "type": "float", "default": 1.0, "min": 0.0, "max": 10000.0, "uniform": "uSeed"}
  ],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": []},
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["glitch", "noise", "grain", "digital"]
}
