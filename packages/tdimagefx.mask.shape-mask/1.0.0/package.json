{
  "schema_version": 1,
  "id": "tdimagefx.mask.shape-mask",
  "name": "Shape Mask",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "mask",
  "channel": "experimental",
  "description": "Applies a signed-distance rectangle-to-ellipse mask with adjustable roundness, rotation, and feather.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/shape_mask.frag", "touchdesigner_component": "tox/tdimagefx_mask_shape_mask.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "Image whose alpha receives the generated mask."}],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the mask when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and masked alpha."},
    {"id": "center", "name": "Center", "label": "Center", "type": "xy", "default": [0.5, 0.5], "min": -1.0, "max": 2.0, "unit": "normalized", "uniform": "uCenter", "description": "Shape center."},
    {"id": "size", "name": "Size", "label": "Size", "type": "xy", "default": [0.65, 0.65], "min": 0.001, "max": 4.0, "unit": "normalized", "uniform": "uSize", "description": "Shape width and height."},
    {"id": "roundness", "name": "Roundness", "label": "Roundness", "type": "float", "default": 0.2, "min": 0.0, "max": 1.0, "uniform": "uRoundness", "description": "Morphs sharp corners toward a rounded shape."},
    {"id": "rotation", "name": "Rotation", "label": "Rotation", "type": "float", "default": 0.0, "min": -6.283185, "max": 6.283185, "unit": "radians", "uniform": "uRotation", "description": "Shape rotation."},
    {"id": "feather", "name": "Feather", "label": "Feather", "type": "float", "default": 0.02, "min": 0.0001, "max": 0.5, "unit": "normalized", "uniform": "uFeather", "description": "Soft edge width."},
    {"id": "invert", "name": "Invert", "label": "Invert", "type": "toggle", "default": false, "uniform": "uInvert", "description": "Inverts the generated mask."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["mask", "shape", "rectangle", "ellipse", "alpha"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/shape_mask.frag"], "history_frames": 0}
}
