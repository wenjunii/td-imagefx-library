{
  "schema_version": 1,
  "id": "tdimagefx.distort.displacement-map",
  "name": "Displacement Map",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "distortion",
  "channel": "stable",
  "description": "Offsets image sampling with the red and green channels of a second TOP.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/displacement_map.frag", "touchdesigner_component": "tox/tdimagefx_distort_displacement_map.tox"},
  "inputs": [
    {"id": "image", "family": "TOP", "required": true},
    {"id": "displacement", "family": "TOP", "required": true, "semantic": "displacement_map"}
  ],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "amount_x", "name": "Amountx", "label": "Amount X", "type": "float", "default": 0.05, "min": -0.5, "max": 0.5, "uniform": "uAmountX"},
    {"id": "amount_y", "name": "Amounty", "label": "Amount Y", "type": "float", "default": 0.05, "min": -0.5, "max": 0.5, "uniform": "uAmountY"},
    {"id": "midpoint", "name": "Midpoint", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uMidpoint"},
    {"id": "map_scale", "name": "Mapscale", "label": "Map Scale", "type": "float", "default": 1.0, "min": 0.1, "max": 20.0, "uniform": "uMapScale"}
  ],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": ["second_input", "displacement"]},
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "first_input",
  "stateful": false,
  "tags": ["displacement", "map", "warp", "two-input"]
}
