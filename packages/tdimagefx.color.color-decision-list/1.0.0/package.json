{
  "schema_version": 1,
  "id": "tdimagefx.color.color-decision-list",
  "name": "Color Decision List",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "experimental",
  "description": "Applies ASC-CDL-style slope, offset, power, and saturation controls without silently changing color space.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/color_decision_list.frag", "touchdesigner_component": "tox/tdimagefx_color_color_decision_list.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "Image in the project's intended grading color context."}],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the grade when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and graded output."},
    {"id": "slope", "name": "Slope", "label": "Slope", "type": "xyz", "default": [1.0, 1.0, 1.0], "min": 0.0, "max": 4.0, "uniform": "uSlope", "description": "Per-channel CDL slope."},
    {"id": "offset", "name": "Offset", "label": "Offset", "type": "xyz", "default": [0.0, 0.0, 0.0], "min": -2.0, "max": 2.0, "uniform": "uOffset", "description": "Per-channel CDL offset."},
    {"id": "power", "name": "Power", "label": "Power", "type": "xyz", "default": [1.0, 1.0, 1.0], "min": 0.01, "max": 4.0, "uniform": "uPower", "description": "Per-channel CDL power."},
    {"id": "saturation", "name": "Saturation", "label": "Saturation", "type": "float", "default": 1.0, "min": 0.0, "max": 4.0, "uniform": "uSaturation", "description": "Saturation applied after slope, offset, and power."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["color", "cdl", "grading", "slope-offset-power", "saturation"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/color_decision_list.frag"], "history_frames": 0}
}
