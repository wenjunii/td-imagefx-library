{
  "schema_version": 1,
  "id": "tdimagefx.color.duotone",
  "name": "Duotone",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Maps image luminance between two configurable colors.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/duotone.frag",
    "touchdesigner_component": "tox/tdimagefx_color_duotone.tox"
  },
  "inputs": [
    {"id": "image", "family": "TOP", "required": true}
  ],
  "outputs": [
    {"id": "image", "family": "TOP"}
  ],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "shadow_color", "name": "Shadowcolor", "label": "Shadow Color", "type": "rgba", "default": [0.02, 0.05, 0.15, 1.0], "uniform": "uShadowColor"},
    {"id": "highlight_color", "name": "Highlightcolor", "label": "Highlight Color", "type": "rgba", "default": [1.0, 0.55, 0.12, 1.0], "uniform": "uHighlightColor"},
    {"id": "contrast", "name": "Contrast", "type": "float", "default": 1.0, "min": 0.0, "max": 3.0, "uniform": "uContrast"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["grading", "luminance", "palette"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/duotone.frag"]}
}
