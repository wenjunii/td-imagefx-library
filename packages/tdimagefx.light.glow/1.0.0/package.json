{
  "schema_version": 1,
  "id": "tdimagefx.light.glow",
  "name": "Glow",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "light",
  "channel": "stable",
  "description": "Extracts luminance into a user-tinted halo, spreads it in two stages, and composites it over the source.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/pass1.frag",
    "touchdesigner_component": "tox/tdimagefx_light_glow.tox"
  },
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "threshold", "name": "Threshold", "type": "float", "default": 0.35, "min": 0.0, "max": 2.0, "uniform": "uThreshold"},
    {"id": "spread", "name": "Spread", "type": "float", "default": 10.0, "min": 0.0, "max": 64.0, "unit": "pixels", "uniform": "uSpread"},
    {"id": "intensity", "name": "Intensity", "type": "float", "default": 1.25, "min": 0.0, "max": 8.0, "uniform": "uIntensity"},
    {"id": "glow_color", "name": "Glowcolor", "label": "Glow Color", "type": "rgba", "default": [0.35, 0.7, 1.0, 1.0], "uniform": "uGlowColor"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["light", "glow", "halo", "color", "multi-pass"],
  "processing": {
    "model": "multi_pass",
    "gpu_cost": "high",
    "capabilities": ["multi_pass"],
    "passes": ["shaders/pass1.frag", "shaders/pass2.frag", "shaders/pass3.frag"]
  }
}
