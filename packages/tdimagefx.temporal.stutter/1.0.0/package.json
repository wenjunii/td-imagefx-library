{
  "schema_version": 1,
  "id": "tdimagefx.temporal.stutter",
  "name": "Stutter",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "temporal",
  "channel": "stable",
  "description": "Freezes feedback state on demand for rhythmic frame-hold effects.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/stutter.frag",
    "touchdesigner_component": "tox/tdimagefx_temporal_stutter.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "hold",
      "name": "Hold",
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 1,
      "uniform": "uHold"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "stutter",
    "freeze",
    "hold",
    "history"
  ],
  "processing": {
    "model": "temporal",
    "gpu_cost": "low",
    "capabilities": [
      "history"
    ],
    "passes": [
      "shaders/stutter.frag"
    ],
    "history_frames": 1
  }
}
