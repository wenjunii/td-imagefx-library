{
  "schema_version": 1,
  "id": "tdimagefx.glitch.block-shift",
  "name": "Block Shift",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "glitch",
  "channel": "stable",
  "description": "Animates deterministic horizontal offsets across randomized image blocks.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/block_shift.frag", "touchdesigner_component": "tox/tdimagefx_glitch_block_shift.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "time", "name": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "uniform": "uTime"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.08, "min": 0.0, "max": 0.5, "uniform": "uAmount"},
    {"id": "block_size", "name": "Blocksize", "label": "Block Size", "type": "float", "default": 18.0, "min": 2.0, "max": 128.0, "uniform": "uBlockSize"},
    {"id": "rate", "name": "Rate", "type": "float", "default": 8.0, "min": 0.0, "max": 60.0, "uniform": "uRate"},
    {"id": "seed", "name": "Seed", "type": "float", "default": 1.0, "min": 0.0, "max": 10000.0, "uniform": "uSeed"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["digital", "blocks", "animated"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/block_shift.frag"]}
}
