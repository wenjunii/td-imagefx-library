{
  "schema_version": 1,
  "id": "tdimagefx.blur.tilt-shift",
  "name": "Tilt Shift",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "blur",
  "channel": "stable",
  "description": "Keeps a horizontal focus band sharp while applying a separable variable-radius blur outside it.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/pass1.frag",
    "touchdesigner_component": "tox/tdimagefx_blur_tilt_shift.tox"
  },
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "radius", "name": "Radius", "type": "float", "default": 14.0, "min": 0.0, "max": 64.0, "unit": "pixels", "uniform": "uRadius"},
    {"id": "focus", "name": "Focus", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uFocus"},
    {"id": "band_width", "name": "Bandwidth", "label": "Band Width", "type": "float", "default": 0.12, "min": 0.0, "max": 0.5, "uniform": "uBandWidth"},
    {"id": "feather", "name": "Feather", "type": "float", "default": 0.25, "min": 0.001, "max": 0.75, "uniform": "uFeather"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["blur", "tilt-shift", "focus", "miniature", "multi-pass"],
  "processing": {
    "model": "multi_pass",
    "gpu_cost": "medium",
    "capabilities": ["multi_pass"],
    "passes": ["shaders/pass1.frag", "shaders/pass2.frag"]
  }
}
