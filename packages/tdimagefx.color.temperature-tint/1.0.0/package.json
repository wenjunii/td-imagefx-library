{
  "schema_version": 1,
  "id": "tdimagefx.color.temperature-tint",
  "name": "Temperature Tint",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Balances warm-to-cool temperature and green-to-magenta tint while retaining luminance.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/temperature_tint.frag", "touchdesigner_component": "tox/tdimagefx_color_temperature_tint.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "temperature", "name": "Temperature", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uTemperature"},
    {"id": "tint", "name": "Tint", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uTint"},
    {"id": "strength", "name": "Strength", "type": "float", "default": 1.0, "min": 0.0, "max": 2.0, "uniform": "uStrength"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["white-balance", "temperature", "tint", "grading"]
}
