{
  "schema_version": 1,
  "id": "tdimagefx.color.hsv-shift",
  "name": "HSV Shift",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Animatable hue, saturation, and value adjustment in HSV color space.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/hsv_shift.frag", "touchdesigner_component": "tox/tdimagefx_color_hsv_shift.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "hue", "name": "Hue", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uHue"},
    {"id": "saturation", "name": "Saturation", "type": "float", "default": 1.0, "min": 0.0, "max": 3.0, "uniform": "uSaturation"},
    {"id": "value", "name": "Value", "type": "float", "default": 1.0, "min": 0.0, "max": 3.0, "uniform": "uValue"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["hue", "saturation", "color-cycle"]
}
