{
  "schema_version": 1,
  "id": "tdimagefx.stylize.edge-detect",
  "name": "Edge Detect",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "stylize",
  "channel": "stable",
  "description": "Extracts adjustable Sobel-style luminance edges with monochrome and source-color modes.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/edge_detect.frag", "touchdesigner_component": "tox/tdimagefx_stylize_edge_detect.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "radius", "name": "Radius", "type": "float", "default": 1.0, "min": 0.5, "max": 8.0, "uniform": "uRadius", "unit": "pixels"},
    {"id": "strength", "name": "Strength", "type": "float", "default": 2.0, "min": 0.0, "max": 10.0, "uniform": "uStrength"},
    {"id": "threshold", "name": "Threshold", "type": "float", "default": 0.08, "min": 0.0, "max": 1.0, "uniform": "uThreshold"},
    {"id": "softness", "name": "Softness", "type": "float", "default": 0.12, "min": 0.001, "max": 1.0, "uniform": "uSoftness"},
    {"id": "invert", "name": "Invert", "type": "toggle", "default": false, "uniform": "uInvert"},
    {"id": "color_amount", "name": "Coloramount", "label": "Color Amount", "type": "float", "default": 0.0, "min": 0.0, "max": 1.0, "uniform": "uColorAmount"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": []},
  "tags": ["edges", "sobel", "outline", "contour"]
}
