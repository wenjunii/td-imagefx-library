{
  "schema_version": 1,
  "id": "tdimagefx.distort.kaleidoscope",
  "name": "Kaleidoscope",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "distortion",
  "channel": "stable",
  "description": "Reflects polar wedges to form an animatable kaleidoscope.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/kaleidoscope.frag", "touchdesigner_component": "tox/tdimagefx_distort_kaleidoscope.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "segments", "name": "Segments", "type": "float", "default": 8.0, "min": 2.0, "max": 32.0, "uniform": "uSegments"},
    {"id": "rotation", "name": "Rotation", "type": "float", "default": 0.0, "min": -6.28318, "max": 6.28318, "uniform": "uRotation"},
    {"id": "zoom", "name": "Zoom", "type": "float", "default": 1.0, "min": 0.1, "max": 5.0, "uniform": "uZoom"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["mirror", "polar", "symmetry"],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": [], "passes": ["shaders/kaleidoscope.frag"]}
}
