{
  "schema_version": 1,
  "id": "tdimagefx.blur.radial-blur",
  "name": "Radial Blur",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "blur",
  "channel": "stable",
  "description": "Creates a center-controlled zoom blur using two progressive radial integration passes.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/pass1.frag",
    "touchdesigner_component": "tox/tdimagefx_blur_radial_blur.tox"
  },
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "strength", "name": "Strength", "type": "float", "default": 0.12, "min": 0.0, "max": 0.75, "uniform": "uStrength"},
    {"id": "center_x", "name": "Centerx", "label": "Center X", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uCenterX"},
    {"id": "center_y", "name": "Centery", "label": "Center Y", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uCenterY"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["blur", "radial", "zoom", "multi-pass"],
  "processing": {
    "model": "multi_pass",
    "gpu_cost": "high",
    "capabilities": ["multi_pass"],
    "passes": ["shaders/pass1.frag", "shaders/pass2.frag"]
  }
}
