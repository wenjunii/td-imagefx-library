{
  "schema_version": 1,
  "id": "tdimagefx.matte.alpha-repair",
  "name": "Alpha Repair",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "matte",
  "channel": "experimental",
  "description": "Cleans hidden RGB, premultiplies, or safely unpremultiplies an RGBA image.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/alpha_repair.frag", "touchdesigner_component": "tox/tdimagefx_matte_alpha_repair.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "RGBA image to repair or convert."}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass repair when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and repaired result."},
    {"id": "mode", "name": "Mode", "label": "Mode", "type": "float", "default": 0.0, "min": 0.0, "max": 2.0, "uniform": "uMode", "description": "0 Clean hidden RGB, 1 Premultiply, 2 Unpremultiply."},
    {"id": "threshold", "name": "Threshold", "label": "Alpha Threshold", "type": "float", "default": 0.001, "min": 0.0, "max": 1.0, "uniform": "uThreshold", "description": "Alpha below which hidden RGB is cleared or division is suppressed."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "configurable",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["matte", "alpha", "premultiply", "unpremultiply", "repair"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/alpha_repair.frag"], "history_frames": 0}
}
