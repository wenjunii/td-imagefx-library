{
  "schema_version": 1,
  "id": "tdimagefx.composite.edge-extend",
  "name": "Edge Extend",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "composite",
  "channel": "experimental",
  "description": "Extends opaque RGB into transparent pixels to reduce filtering fringes while preserving source alpha.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/edge_extend.frag", "touchdesigner_component": "tox/tdimagefx_composite_edge_extend.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "RGBA image whose hidden RGB should be extended."}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass edge extension when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and repaired RGB."},
    {"id": "radius", "name": "Radius", "label": "Radius", "type": "float", "default": 4.0, "min": 1.0, "max": 8.0, "unit": "pixels", "uniform": "uRadius", "description": "Maximum neighbor-search distance."},
    {"id": "threshold", "name": "Threshold", "label": "Alpha Threshold", "type": "float", "default": 0.01, "min": 0.0, "max": 1.0, "uniform": "uThreshold", "description": "Only pixels below this alpha receive extended RGB."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["composite", "alpha", "edge", "extend", "fringe"],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": [], "passes": ["shaders/edge_extend.frag"], "history_frames": 0}
}
