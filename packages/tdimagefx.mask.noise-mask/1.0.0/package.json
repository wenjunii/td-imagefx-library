{
  "schema_version": 1,
  "id": "tdimagefx.mask.noise-mask",
  "name": "Noise Mask",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "mask",
  "channel": "experimental",
  "description": "Applies a deterministic animated fractal-noise mask to source alpha.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/noise_mask.frag", "touchdesigner_component": "tox/tdimagefx_mask_noise_mask.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "Image whose alpha receives the generated mask."}],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the mask when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and masked alpha."},
    {"id": "scale", "name": "Scale", "label": "Scale", "type": "float", "default": 6.0, "min": 0.1, "max": 64.0, "uniform": "uScale", "description": "Spatial frequency of the noise."},
    {"id": "threshold", "name": "Threshold", "label": "Threshold", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uThreshold", "description": "Noise level around which the matte transitions."},
    {"id": "softness", "name": "Softness", "label": "Softness", "type": "float", "default": 0.12, "min": 0.0001, "max": 1.0, "uniform": "uSoftness", "description": "Width of the matte transition."},
    {"id": "seed", "name": "Seed", "label": "Seed", "type": "float", "default": 0.0, "min": 0.0, "max": 10000.0, "uniform": "uSeed", "description": "Deterministic noise seed."},
    {"id": "time", "name": "Time", "label": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "unit": "seconds", "uniform": "uTime", "description": "Animation time supplied by the effect or rack clock."},
    {"id": "speed", "name": "Speed", "label": "Speed", "type": "float", "default": 0.2, "min": -10.0, "max": 10.0, "uniform": "uSpeed", "description": "Noise animation speed."},
    {"id": "invert", "name": "Invert", "label": "Invert", "type": "toggle", "default": false, "uniform": "uInvert", "description": "Inverts the generated mask."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "seeded", "seed_parameter": "seed"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["mask", "noise", "animated", "alpha", "generator"],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": [], "passes": ["shaders/noise_mask.frag"], "history_frames": 0}
}
