{
  "schema_version": 1,
  "id": "tdimagefx.glitch.rgb-split",
  "name": "RGB Split",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "glitch",
  "channel": "stable",
  "description": "Offsets red, green, and blue samples in opposing directions.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/rgb_split.frag", "touchdesigner_component": "tox/tdimagefx_glitch_rgb_split.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.01, "min": 0.0, "max": 0.15, "uniform": "uAmount"},
    {"id": "angle", "name": "Angle", "type": "float", "default": 0.0, "min": -3.14159, "max": 3.14159, "uniform": "uAngle"},
    {"id": "green_offset", "name": "Greenoffset", "label": "Green Offset", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uGreenOffset"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["chromatic", "aberration", "glitch"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/rgb_split.frag"]}
}
