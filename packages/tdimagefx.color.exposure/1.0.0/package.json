{
  "schema_version": 1,
  "id": "tdimagefx.color.exposure",
  "name": "Exposure",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Adjusts exposure in photographic stops with offset and pivoted contrast controls.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/exposure.frag", "touchdesigner_component": "tox/tdimagefx_color_exposure.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "exposure", "name": "Exposure", "type": "float", "default": 0.0, "min": -8.0, "max": 8.0, "uniform": "uExposure", "unit": "stops"},
    {"id": "offset", "name": "Offset", "type": "float", "default": 0.0, "min": -1.0, "max": 1.0, "uniform": "uOffset"},
    {"id": "contrast", "name": "Contrast", "type": "float", "default": 1.0, "min": 0.0, "max": 4.0, "uniform": "uContrast"},
    {"id": "pivot", "name": "Pivot", "type": "float", "default": 0.18, "min": 0.0, "max": 1.0, "uniform": "uPivot"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "tags": ["exposure", "contrast", "grading", "photographic"]
}
