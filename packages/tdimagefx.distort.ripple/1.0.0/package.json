{
  "schema_version": 1,
  "id": "tdimagefx.distort.ripple",
  "name": "Ripple",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "distortion",
  "channel": "stable",
  "description": "Animates concentric, decaying image ripples from a movable origin.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/ripple.frag", "touchdesigner_component": "tox/tdimagefx_distort_ripple.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "time", "name": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "uniform": "uTime"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.02, "min": -0.15, "max": 0.15, "uniform": "uAmount"},
    {"id": "frequency", "name": "Frequency", "type": "float", "default": 12.0, "min": 0.1, "max": 60.0, "uniform": "uFrequency"},
    {"id": "speed", "name": "Speed", "type": "float", "default": 1.0, "min": -10.0, "max": 10.0, "uniform": "uSpeed"},
    {"id": "decay", "name": "Decay", "type": "float", "default": 2.0, "min": 0.0, "max": 12.0, "uniform": "uDecay"},
    {"id": "center_x", "name": "Centerx", "label": "Center X", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uCenterX"},
    {"id": "center_y", "name": "Centery", "label": "Center Y", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uCenterY"}
  ],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": []},
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["ripple", "water", "radial", "animated"]
}
