{
  "schema_version": 1,
  "id": "tdimagefx.stylize.vignette",
  "name": "Vignette",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "stylize",
  "channel": "stable",
  "description": "Darkens or colors image edges with adjustable roundness and softness.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/vignette.frag", "touchdesigner_component": "tox/tdimagefx_stylize_vignette.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.65, "min": -1.0, "max": 1.0, "uniform": "uAmount"},
    {"id": "softness", "name": "Softness", "type": "float", "default": 0.45, "min": 0.001, "max": 1.0, "uniform": "uSoftness"},
    {"id": "roundness", "name": "Roundness", "type": "float", "default": 1.0, "min": 0.25, "max": 3.0, "uniform": "uRoundness"},
    {"id": "color", "name": "Color", "type": "rgba", "default": [0.0, 0.0, 0.0, 1.0], "uniform": "uColor"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["lens", "edge", "cinematic"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/vignette.frag"]}
}
