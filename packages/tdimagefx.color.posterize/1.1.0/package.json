{
  "schema_version": 1,
  "id": "tdimagefx.color.posterize",
  "name": "Posterize",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "color",
  "channel": "stable",
  "description": "Quantizes RGB channels into a configurable number of color levels.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/posterize.frag", "touchdesigner_component": "tox/tdimagefx_color_posterize.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "levels", "name": "Levels", "type": "float", "default": 6.0, "min": 2.0, "max": 64.0, "uniform": "uLevels"},
    {"id": "gamma", "name": "Gamma", "type": "float", "default": 1.0, "min": 0.1, "max": 4.0, "uniform": "uGamma"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["quantize", "graphic", "color"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/posterize.frag"]}
}
