{
  "schema_version": 1,
  "id": "tdimagefx.light.edge-glow",
  "name": "Edge Glow",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "light",
  "channel": "stable",
  "description": "Detects luminance edges with a Sobel pass, softens the edge field, and adds a colored glow to the source.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/pass1.frag",
    "touchdesigner_component": "tox/tdimagefx_light_edge_glow.tox"
  },
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "edge_width", "name": "Edgewidth", "label": "Edge Width", "type": "float", "default": 1.0, "min": 0.5, "max": 8.0, "unit": "pixels", "uniform": "uEdgeWidth"},
    {"id": "threshold", "name": "Threshold", "type": "float", "default": 0.08, "min": 0.0, "max": 1.0, "uniform": "uThreshold"},
    {"id": "radius", "name": "Radius", "type": "float", "default": 5.0, "min": 0.0, "max": 32.0, "unit": "pixels", "uniform": "uRadius"},
    {"id": "intensity", "name": "Intensity", "type": "float", "default": 1.5, "min": 0.0, "max": 8.0, "uniform": "uIntensity"},
    {"id": "glow_color", "name": "Glowcolor", "label": "Glow Color", "type": "rgba", "default": [0.1, 0.8, 1.0, 1.0], "uniform": "uGlowColor"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["light", "edge", "sobel", "glow", "multi-pass"],
  "processing": {
    "model": "multi_pass",
    "gpu_cost": "high",
    "capabilities": ["multi_pass"],
    "passes": ["shaders/pass1.frag", "shaders/pass2.frag", "shaders/pass3.frag"]
  }
}
