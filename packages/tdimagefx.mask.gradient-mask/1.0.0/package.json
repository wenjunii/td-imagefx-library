{
  "schema_version": 1,
  "id": "tdimagefx.mask.gradient-mask",
  "name": "Gradient Mask",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "mask",
  "channel": "experimental",
  "description": "Applies a rotatable linear gradient to source alpha with position, width, softness, and inversion controls.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/gradient_mask.frag", "touchdesigner_component": "tox/tdimagefx_mask_gradient_mask.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "Image whose alpha receives the generated mask."}],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the mask when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and masked alpha."},
    {"id": "angle", "name": "Angle", "label": "Angle", "type": "float", "default": 0.0, "min": -6.283185, "max": 6.283185, "unit": "radians", "uniform": "uAngle", "description": "Gradient direction."},
    {"id": "position", "name": "Position", "label": "Position", "type": "float", "default": 0.5, "min": -1.0, "max": 2.0, "unit": "normalized", "uniform": "uPosition", "description": "Center of the gradient transition."},
    {"id": "width", "name": "Width", "label": "Width", "type": "float", "default": 0.5, "min": 0.0001, "max": 2.0, "unit": "normalized", "uniform": "uWidth", "description": "Distance over which the mask rises from black to white."},
    {"id": "softness", "name": "Softness", "label": "Softness", "type": "float", "default": 1.0, "min": 0.01, "max": 4.0, "uniform": "uSoftness", "description": "Shapes the gradient transition."},
    {"id": "invert", "name": "Invert", "label": "Invert", "type": "toggle", "default": false, "uniform": "uInvert", "description": "Inverts the generated mask."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["mask", "gradient", "linear", "alpha", "generator"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/gradient_mask.frag"], "history_frames": 0}
}
