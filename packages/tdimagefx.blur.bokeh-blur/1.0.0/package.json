{
  "schema_version": 1,
  "id": "tdimagefx.blur.bokeh-blur",
  "name": "Bokeh Blur",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "blur",
  "channel": "experimental",
  "description": "Creates a circular or polygonal bokeh blur with highlight weighting and deterministic sampling.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/bokeh_blur.frag", "touchdesigner_component": "tox/tdimagefx_blur_bokeh_blur.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "role": "source_image", "description": "Image to defocus."}],
  "outputs": [{"id": "image", "family": "TOP", "role": "image"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the blur when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and bokeh output."},
    {"id": "radius", "name": "Radius", "label": "Radius", "type": "float", "default": 8.0, "min": 0.0, "max": 64.0, "unit": "pixels", "uniform": "uRadius", "description": "Maximum defocus radius."},
    {"id": "samples", "name": "Samples", "label": "Samples", "type": "float", "default": 24.0, "min": 6.0, "max": 32.0, "uniform": "uSamples", "description": "Number of deterministic aperture samples."},
    {"id": "blades", "name": "Blades", "label": "Aperture Blades", "type": "float", "default": 8.0, "min": 3.0, "max": 12.0, "uniform": "uBlades", "description": "Number of aperture blades; high values approach a circle."},
    {"id": "highlight", "name": "Highlight", "label": "Highlight Gain", "type": "float", "default": 0.5, "min": 0.0, "max": 4.0, "uniform": "uHighlight", "description": "Extra weight assigned to bright samples."}
