{
  "schema_version": 1,
  "id": "tdimagefx.distort.mirror",
  "name": "Mirror",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "distortion",
  "channel": "stable",
  "description": "Folds either image axis across independently positioned mirror seams.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/mirror.frag", "touchdesigner_component": "tox/tdimagefx_distort_mirror.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "horizontal", "name": "Horizontal", "type": "toggle", "default": true, "uniform": "uHorizontal"},
    {"id": "vertical", "name": "Vertical", "type": "toggle", "default": false, "uniform": "uVertical"},
    {"id": "seam_x", "name": "Seamx", "label": "Seam X", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uSeamX"},
    {"id": "seam_y", "name": "Seamy", "label": "Seam Y", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "uniform": "uSeamY"}
  ],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["mirror", "reflection", "symmetry", "fold"]
}
