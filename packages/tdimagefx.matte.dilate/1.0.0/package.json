{
  "schema_version": 1,
  "id": "tdimagefx.matte.dilate",
  "name": "Matte Dilate",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "matte",
  "channel": "experimental",
  "description": "Expands alpha while borrowing RGB from the most opaque nearby sample to avoid dark fringes.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/matte_dilate.frag", "touchdesigner_component": "tox/tdimagefx_matte_dilate.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "RGBA image containing the matte to expand."}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass dilation when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends source and dilated matte."},
    {"id": "radius", "name": "Radius", "label": "Radius", "type": "float", "default": 2.0, "min": 0.0, "max": 8.0, "unit": "pixels", "uniform": "uRadius", "description": "Expansion radius in pixels."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["matte", "dilate", "grow", "alpha", "morphology"],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": [], "passes": ["shaders/matte_dilate.frag"], "history_frames": 0}
}
