{
  "schema_version": 1,
  "id": "tdimagefx.composite.alpha-composite",
  "name": "Alpha Composite",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "composite",
  "channel": "experimental",
  "description": "Composites a foreground over a background with straight or premultiplied foreground handling.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/alpha_composite.frag", "touchdesigner_component": "tox/tdimagefx_composite_alpha_composite.tox"},
  "inputs": [
    {"id": "image", "family": "TOP", "required": true, "semantic": "foreground", "description": "Foreground image."},
    {"id": "image_b", "family": "TOP", "required": true, "semantic": "background", "description": "Background image."}
  ],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass compositing when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends foreground input and composite output."},
    {"id": "opacity", "name": "Opacity", "label": "Foreground Opacity", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uOpacity", "description": "Scales foreground alpha."},
    {"id": "premultiplied", "name": "Premultiplied", "label": "Foreground Premultiplied", "type": "toggle", "default": false, "uniform": "uPremultiplied", "description": "Treats foreground RGB as already multiplied by alpha."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "blend",
  "resolution_policy": "first_input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["composite", "alpha", "over", "premultiply", "two-input"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": ["second_input"], "passes": ["shaders/alpha_composite.frag"], "history_frames": 0}
}
