{
  "schema_version": 1,
  "id": "tdimagefx.glitch.scan-tear",
  "name": "Scan Tear",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "glitch",
  "channel": "stable",
  "description": "Produces frame-stepped horizontal tears across randomized scan bands.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/scan_tear.frag", "touchdesigner_component": "tox/tdimagefx_glitch_scan_tear.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "time", "name": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "uniform": "uTime"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.12, "min": 0.0, "max": 0.75, "uniform": "uAmount"},
    {"id": "bands", "name": "Bands", "type": "float", "default": 48.0, "min": 2.0, "max": 256.0, "uniform": "uBands"},
    {"id": "rate", "name": "Rate", "type": "float", "default": 12.0, "min": 0.0, "max": 60.0, "uniform": "uRate"},
    {"id": "chance", "name": "Chance", "type": "float", "default": 0.22, "min": 0.0, "max": 1.0, "uniform": "uChance"},
    {"id": "seed", "name": "Seed", "type": "float", "default": 1.0, "min": 0.0, "max": 10000.0, "uniform": "uSeed"}
  ],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": []},
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["glitch", "tear", "scan", "animated"]
}
