{
  "schema_version": 1,
  "id": "tdimagefx.temporal.recursive-zoom",
  "name": "Recursive Zoom",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "temporal",
  "channel": "stable",
  "description": "Recursively zooms feedback around a movable center to form tunnel trails.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/recursive_zoom.frag",
    "touchdesigner_component": "tox/tdimagefx_temporal_recursive_zoom.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "zoom",
      "name": "Zoom",
      "type": "float",
      "default": 1.015,
      "min": 0.8,
      "max": 1.2,
      "uniform": "uZoom"
    },
    {
      "id": "feedback",
      "name": "Feedback",
      "type": "float",
      "default": 0.88,
      "min": 0,
      "max": 0.995,
      "uniform": "uFeedback"
    },
    {
      "id": "center_x",
      "name": "Centerx",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "uniform": "uCenterX"
    },
    {
      "id": "center_y",
      "name": "Centery",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "uniform": "uCenterY"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "feedback",
    "zoom",
    "tunnel",
    "history"
  ],
  "processing": {
    "model": "temporal",
    "gpu_cost": "medium",
    "capabilities": [
      "history"
    ],
    "passes": [
      "shaders/recursive_zoom.frag"
    ],
    "history_frames": 1
  }
}
