{
  "schema_version": 1,
  "id": "tdimagefx.stylize.vhs",
  "name": "VHS",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "stylize",
  "channel": "stable",
  "description": "Combines animated line jitter, chroma delay, scanlines, noise, and tracking distortion.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/vhs.frag", "touchdesigner_component": "tox/tdimagefx_stylize_vhs.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "time", "name": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "uniform": "uTime"},
    {"id": "jitter", "name": "Jitter", "type": "float", "default": 0.008, "min": 0.0, "max": 0.08, "uniform": "uJitter"},
    {"id": "jitter_rate", "name": "Jitterrate", "label": "Jitter Rate", "type": "float", "default": 12.0, "min": 0.0, "max": 60.0, "uniform": "uJitterRate"},
    {"id": "chroma_delay", "name": "Chromadelay", "label": "Chroma Delay", "type": "float", "default": 3.0, "min": 0.0, "max": 24.0, "uniform": "uChromaDelay", "unit": "pixels"},
    {"id": "scanline_strength", "name": "Scanlinestrength", "label": "Scanline Strength", "type": "float", "default": 0.16, "min": 0.0, "max": 1.0, "uniform": "uScanlineStrength"},
    {"id": "noise", "name": "Noise", "type": "float", "default": 0.06, "min": 0.0, "max": 0.5, "uniform": "uNoise"},
    {"id": "tracking", "name": "Tracking", "type": "float", "default": 0.02, "min": 0.0, "max": 0.15, "uniform": "uTracking"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": []},
  "tags": ["analog", "tape", "scanlines", "glitch", "animated"]
}
