{
  "schema_version": 1,
  "id": "tdimagefx.transform.transform-2d",
  "name": "Transform 2D",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "transform",
  "channel": "experimental",
  "description": "Applies pivoted translation, rotation, and non-uniform scale with optional repeated edges.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/transform_2d.frag",
    "touchdesigner_component": "tox/tdimagefx_transform_transform_2d.tox"
  },
  "inputs": [
    {"id": "image", "family": "TOP", "required": true, "semantic": "source", "description": "Image to transform."}
  ],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "label": "Enable", "type": "toggle", "default": true, "description": "Bypass the transform when disabled."},
    {"id": "mix", "name": "Mix", "label": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix", "description": "Blends between the source and transformed image."},
    {"id": "translate", "name": "Translate", "label": "Translate", "type": "xy", "default": [0.0, 0.0], "min": -2.0, "max": 2.0, "unit": "normalized", "uniform": "uTranslate", "description": "Horizontal and vertical offset in normalized image coordinates."},
    {"id": "scale", "name": "Scale", "label": "Scale", "type": "xy", "default": [1.0, 1.0], "min": 0.01, "max": 8.0, "uniform": "uScale", "description": "Horizontal and vertical scale around the pivot."},
    {"id": "rotation", "name": "Rotation", "label": "Rotation", "type": "float", "default": 0.0, "min": -6.283185, "max": 6.283185, "unit": "radians", "uniform": "uRotation", "description": "Clockwise rotation around the pivot."},
    {"id": "pivot", "name": "Pivot", "label": "Pivot", "type": "xy", "default": [0.5, 0.5], "min": -1.0, "max": 2.0, "unit": "normalized", "uniform": "uPivot", "description": "Center used for scale and rotation."},
    {"id": "repeat", "name": "Repeat", "label": "Repeat Outside", "type": "toggle", "default": false, "uniform": "uRepeat", "description": "Tiles the image instead of returning transparent pixels outside its bounds."}
  ],
  "compatibility": {"touchdesigner_min_build": 2025.3, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "process",
  "resolution_policy": "input",
  "stateful": false,
  "image_contract": {
    "color": {"input_space": "source", "working_space": "project", "output_space": "source", "reference": "display_referred"},
    "alpha": {"input": "any", "working": "any", "output": "any"},
    "pixel_format": {"policy": "inherit"},
    "sampling": {"filter": "linear", "edge": "clamp", "mipmaps": false}
  },
  "determinism": {"mode": "deterministic"},
  "provenance": {"origin": "original", "source": {"type": "original"}},
  "tags": ["transform", "translate", "rotate", "scale", "pivot", "uv"],
  "processing": {"model": "single_pass", "gpu_cost": "low", "capabilities": [], "passes": ["shaders/transform_2d.frag"], "history_frames": 0}
}
