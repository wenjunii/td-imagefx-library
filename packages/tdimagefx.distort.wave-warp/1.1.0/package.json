{
  "schema_version": 1,
  "id": "tdimagefx.distort.wave-warp",
  "name": "Wave Warp",
  "version": "1.1.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "distortion",
  "channel": "stable",
  "description": "Applies animated sine-wave displacement along both image axes.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {"shader": "shaders/wave_warp.frag", "touchdesigner_component": "tox/tdimagefx_distort_wave_warp.tox"},
  "inputs": [{"id": "image", "family": "TOP", "required": true}],
  "outputs": [{"id": "image", "family": "TOP"}],
  "parameters": [
    {"id": "enable", "name": "Enable", "type": "toggle", "default": true},
    {"id": "mix", "name": "Mix", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "uniform": "uMix"},
    {"id": "time", "name": "Time", "type": "float", "default": 0.0, "min": -100000.0, "max": 100000.0, "uniform": "uTime"},
    {"id": "amount", "name": "Amount", "type": "float", "default": 0.025, "min": 0.0, "max": 0.25, "uniform": "uAmount"},
    {"id": "frequency", "name": "Frequency", "type": "float", "default": 8.0, "min": 0.1, "max": 50.0, "uniform": "uFrequency"},
    {"id": "speed", "name": "Speed", "type": "float", "default": 1.0, "min": -10.0, "max": 10.0, "uniform": "uSpeed"},
    {"id": "angle", "name": "Angle", "type": "float", "default": 0.0, "min": -3.14159, "max": 3.14159, "uniform": "uAngle"}
  ],
  "compatibility": {"touchdesigner_min_build": 2022.2, "touchdesigner_max_build": null, "os": ["windows", "macos"], "architectures": ["x86_64", "arm64"]},
  "permissions": {"python": false, "filesystem": false, "network": false, "subprocess": false},
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": false,
  "tags": ["wave", "uv", "animated"],
  "processing": {"model": "single_pass", "gpu_cost": "medium", "capabilities": [], "passes": ["shaders/wave_warp.frag"]}
}
