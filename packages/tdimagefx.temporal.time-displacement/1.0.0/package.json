{
  "schema_version": 1,
  "id": "tdimagefx.temporal.time-displacement",
  "name": "Time Displacement",
  "version": "1.0.0",
  "fx_api": "1.0",
  "kind": "effect",
  "category": "temporal",
  "channel": "stable",
  "description": "Selects current or historical pixels from a luminance-driven temporal mask.",
  "publisher": "TD ImageFX Library",
  "license": "MIT",
  "entrypoints": {
    "shader": "shaders/time_displacement.frag",
    "touchdesigner_component": "tox/tdimagefx_temporal_time_displacement.tox"
  },
  "inputs": [
    {
      "id": "image",
      "family": "TOP",
      "required": true,
      "semantic": "source"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "family": "TOP"
    }
  ],
  "parameters": [
    {
      "id": "enable",
      "name": "Enable",
      "type": "toggle",
      "default": true
    },
    {
      "id": "mix",
      "name": "Mix",
      "type": "float",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "uniform": "uMix"
    },
    {
      "id": "amount",
      "name": "Amount",
      "type": "float",
      "default": 0.8,
      "min": 0,
      "max": 1,
      "uniform": "uAmount"
    },
    {
      "id": "phase",
      "name": "Phase",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "uniform": "uPhase"
    },
    {
      "id": "softness",
      "name": "Softness",
      "type": "float",
      "default": 0.08,
      "min": 0.001,
      "max": 0.5,
      "uniform": "uSoftness"
    }
  ],
  "compatibility": {
    "touchdesigner_min_build": 2022.2,
    "touchdesigner_max_build": null,
    "os": [
      "windows",
      "macos"
    ],
    "architectures": [
      "x86_64",
      "arm64"
    ]
  },
  "permissions": {
    "python": false,
    "filesystem": false,
    "network": false,
    "subprocess": false
  },
  "dependencies": [],
  "alpha_policy": "preserve",
  "resolution_policy": "input",
  "stateful": true,
  "tags": [
    "time",
    "displacement",
    "luminance",
    "history"
  ],
  "processing": {
    "model": "temporal",
    "gpu_cost": "medium",
    "capabilities": [
      "history",
      "displacement"
    ],
    "passes": [
      "shaders/time_displacement.frag"
    ],
    "history_frames": 1
  }
}
